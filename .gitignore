# ==============================
# Rarebird Infra — .gitignore
# ==============================

# ── OS Files ──────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Editor & IDE ──────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Logs & Temp ───────────────
*.log
logs/
*.tmp
*.temp
*.bak
*.orig

# ── Secrets (safe habit) ──────
.env
.env.*
*.env

# ── Node (if ever added) ──────
node_modules/
npm-debug.log*
package-lock.json

# ── Build output (if ever added)
dist/
build/
out/

# ── Design source files ───────
# (remove lines below to track these in the repo)
*.psd
*.ai
*.sketch
*.fig

# ── Archives ──────────────────
*.zip
*.tar.gz
*.rar
